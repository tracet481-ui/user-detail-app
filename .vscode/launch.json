{
  "configurations": [
    {
      "name": "Python Debugger: Django",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/back/manage.py",
      "args": ["runserver"],
      "django": true,
      "python": "${workspaceFolder}\\back\\.myenv\\Scripts\\python.exe"
    }
  ]
}




